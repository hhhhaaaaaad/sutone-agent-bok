      <!-- https://github.com/spring-ai-community/spring-ai-agent-utils -->
      <dependency>
        <groupId>org.springaicommunity</groupId>
        <artifactId>spring-ai-agent-utils</artifactId>
        <version>0.4.2</version>
      </dependency>
      <!-- 设计模式框架 -->
      <dependency>
        <groupId>cn.bugstack.wrench</groupId>
        <artifactId>xfg-wrench-starter-design-framework</artifactId>
        <version>3.0.0</version>
      </dependency>
      <!-- 工程模块 -->
      <dependency>
        <groupId>cn.sutone.ai</groupId>
        <artifactId>sutone-agent-bok-api</artifactId>
        <version>1.0</version>
      </dependency>
      <dependency>
        <groupId>cn.sutone.ai</groupId>
        <artifactId>sutone-agent-bok-domain</artifactId>
        <version>1.0</version>
      </dependency>
      <dependency>
        <groupId>cn.sutone.ai</groupId>
        <artifactId>sutone-agent-bok-infrastructure</artifactId>
